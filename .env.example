# OpenAI API Key (optional - for LLM generation)
# RAG AI System Environment Variables

# OpenAI API Key (Optional - for AI-generated responses)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ChromaDB Configuration
CHROMA_PERSIST_DIRECTORY=./chroma_db

# Embedding Model Configuration
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# Server Configuration
HOST=0.0.0.0
PORT=8000
FRONTEND_PORT=3000

# Chunking Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=100

# Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Vector Store Configuration
VECTOR_STORE_TYPE=chroma  # chroma or faiss
CHROMA_PERSIST_DIRECTORY=./chroma_db

# Document Processing
MAX_FILE_SIZE=10485760  # 10MB in bytes
SUPPORTED_FILE_TYPES=pdf,txt,docx,md

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true
